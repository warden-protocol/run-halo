{
  "name": "halo-sdk",
  "version": "0.0.1",
  "description": "x402 client for Halo",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "prepare": "test -d dist || npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@halo/vault-core": "file:../vault-core",
    "ethers": "6.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
